{
  "name": "ocamlgrep VSCode Demo",

  // OCaml 5.4 + opam pre-installed.  The switch is named "5.4" in this image.
  // Alpine ships with a recent opam (2.1+) already pointed at the live opam
  // repository, so no opam upgrade or repo-switching is needed.
  "image": "ocaml/opam:alpine-ocaml-5.4",

  "onCreateCommand": "sudo apk add --no-cache libev-dev pkgconfig build-base curl git bash gcompat && echo 'eval $(opam env)' >> ~/.bashrc && echo 'export PATH=\"$HOME/.bun/bin:$PATH\"' >> ~/.bashrc",

  // Build everything (slow, runs once on container creation).
  "postCreateCommand": "bash /workspace/scripts/setup.sh 2>&1 | tee /tmp/setup.log",

  // Install the built .vsix into VS Code (fast, runs on each attach).
  // Uses a script that searches for the 'code' CLI under ~/.vscode-server
  // if it is not in PATH (which is common in postAttachCommand).
  "postAttachCommand": "bash /workspace/scripts/install-extension.sh",

  "customizations": {
    "vscode": {
      "settings": {
        "ocaml.sandbox": {
          "kind": "global"
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "OPAMSWITCH": "5.4"
        }
      }
    }
  },

  // Expose the opam switch bin dir to the VS Code server process (and thus the
  // OCaml extension) without relying on shell init files being sourced.
  "remoteEnv": {
    "PATH": "/home/opam/.opam/5.4/bin:${containerEnv:PATH}"
  },

  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",

  "remoteUser": "opam"
}
